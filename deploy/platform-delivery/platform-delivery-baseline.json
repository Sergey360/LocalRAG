{
  "schema_version": "1.0",
  "project": {
    "name": "localrag",
    "service_name": "localrag",
    "primary_gitlab_project": "https://lab.it360.ru/myprojects/localrag",
    "gitlab_project_path": "myprojects/localrag",
    "repository_topology": "mono",
    "local_workspace_target": "C:\\Sergey\\Lab360\\localrag",
    "release_version": "0.9.0",
    "default_model": "qwen3.5:9b",
    "default_embedding_model": "intfloat/multilingual-e5-large",
    "runtime_port": 7860
  },
  "environments": [
    {
      "name": "dev",
      "app_env": "dev",
      "git_ref_policy": "dev branch and feature branches",
      "protected": false,
      "url_variable": "LOCALRAG_DEV_BASE_URL",
      "base_url_placeholder": "https://dev.localrag.example.com",
      "data_profile": "developer local documents or safe seeded fixtures",
      "readiness_endpoints": [
        "/api/health",
        "/api/meta"
      ],
      "promotion_gate": "pytest_ci passes; live quality gate optional unless release candidate work depends on it"
    },
    {
      "name": "staging",
      "app_env": "staging",
      "git_ref_policy": "manual deploy from protected dev/main or release candidate tag",
      "protected": true,
      "url_variable": "LOCALRAG_STAGING_BASE_URL",
      "base_url_placeholder": "https://staging.localrag.example.com",
      "data_profile": "safe seeded corpus approved for release smoke and eval",
      "readiness_endpoints": [
        "/api/health",
        "/api/meta",
        "/"
      ],
      "promotion_gate": "pytest_ci, quality_gate_live, release smoke, and required Uptime Kuma checks pass"
    },
    {
      "name": "prod",
      "app_env": "prod",
      "git_ref_policy": "protected tag or protected main release promotion only",
      "protected": true,
      "url_variable": "LOCALRAG_PROD_BASE_URL",
      "base_url_placeholder": "https://localrag.example.com",
      "data_profile": "approved production document source and model cache; no private content in monitoring payloads",
      "readiness_endpoints": [
        "/api/health",
        "/api/meta",
        "/"
      ],
      "promotion_gate": "staging green, tag/package approved, Cloudflare TLS active, monitoring and alert routing armed"
    }
  ],
  "gitlab": {
    "ci_baseline": {
      "pipeline_file": ".gitlab-ci.yml",
      "stages": [
        "test",
        "quality",
        "package",
        "publish"
      ],
      "required_jobs": [
        "pytest_ci"
      ],
      "manual_quality_jobs": [
        "pytest_matrix_manual",
        "quality_gate_live",
        "package_release"
      ],
      "release_jobs": [
        "package_release",
        "github_publish_main",
        "github_publish_tag"
      ],
      "artifact_retention_days": 7,
      "baseline_checks": [
        "python -m py_compile main.py app/app.py",
        "pytest -q",
        "python scripts/release_check.py --base-url \"$LOCALRAG_EVAL_BASE_URL\" --expected-model qwen3.5:9b",
        "python scripts/model_eval.py --base-url \"$LOCALRAG_EVAL_BASE_URL\" --seed-file eval/rag_eval_extended.json --models qwen3.5:9b --output temp/extended_eval_ci.json",
        "python scripts/assert_eval_gate.py --report temp/extended_eval_ci.json --model qwen3.5:9b --min-strict 1.0 --min-loose 1.0 --min-hit-ratio 1.0"
      ]
    },
    "secret_map": [
      {
        "name": "LOCALRAG_EVAL_BASE_URL",
        "scope_envs": [
          "staging",
          "prod"
        ],
        "kind": "url",
        "masked": false,
        "protected": true,
        "required_for": [
          "quality_gate_live"
        ],
        "owner": "release operator",
        "notes": "Base URL for a running LocalRAG candidate. Not a secret, but should be environment-scoped."
      },
      {
        "name": "GITHUB_PUSH_TOKEN",
        "scope_envs": [
          "prod"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "github_publish_main",
          "github_publish_tag"
        ],
        "owner": "repository owner",
        "notes": "Token for the public GitHub mirror publish job."
      },
      {
        "name": "KIWI_USERNAME",
        "scope_envs": [
          "ci"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "kiwi_sync_pytest"
        ],
        "owner": "test manager",
        "notes": "Kiwi TCMS JSON-RPC username when NAS credential fallback is disabled."
      },
      {
        "name": "KIWI_PASSWORD",
        "scope_envs": [
          "ci"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "kiwi_sync_pytest"
        ],
        "owner": "test manager",
        "notes": "Kiwi TCMS JSON-RPC password when NAS credential fallback is disabled."
      },
      {
        "name": "CLOUDFLARE_API_TOKEN",
        "scope_envs": [
          "staging",
          "prod"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "dns_tls_provisioning"
        ],
        "owner": "platform operator",
        "notes": "Least-privilege token for DNS edit and certificate validation automation."
      },
      {
        "name": "CLOUDFLARE_ZONE_ID",
        "scope_envs": [
          "staging",
          "prod"
        ],
        "kind": "identifier",
        "masked": true,
        "protected": true,
        "required_for": [
          "dns_tls_provisioning"
        ],
        "owner": "platform operator",
        "notes": "Cloudflare zone identifier for the LocalRAG hostname."
      },
      {
        "name": "COOLIFY_DEPLOY_WEBHOOK_URL",
        "scope_envs": [
          "dev",
          "staging",
          "prod"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "coolify_manual_or_ci_deploy"
        ],
        "owner": "platform operator",
        "notes": "Coolify deployment webhook for the target application."
      },
      {
        "name": "COOLIFY_API_TOKEN",
        "scope_envs": [
          "staging",
          "prod"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "coolify_application_management"
        ],
        "owner": "platform operator",
        "notes": "Use only if CI manages Coolify application settings; not required for manual webhook deploys."
      },
      {
        "name": "GRAYLOG_HTTP_INPUT_URL",
        "scope_envs": [
          "staging",
          "prod"
        ],
        "kind": "url",
        "masked": false,
        "protected": true,
        "required_for": [
          "graylog_event_ingestion"
        ],
        "owner": "observability operator",
        "notes": "Structured logging input endpoint. Keep private if it exposes internal network naming."
      },
      {
        "name": "GRAYLOG_HTTP_INPUT_TOKEN",
        "scope_envs": [
          "staging",
          "prod"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "graylog_event_ingestion"
        ],
        "owner": "observability operator",
        "notes": "Token or header value for Graylog ingestion when the input requires authentication."
      },
      {
        "name": "UPTIME_KUMA_PUSH_TOKEN",
        "scope_envs": [
          "dev",
          "staging",
          "prod"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "uptime_kuma_push_or_maintenance_api"
        ],
        "owner": "observability operator",
        "notes": "Optional push token or API secret if Uptime Kuma checks are managed from CI."
      },
      {
        "name": "MAYALERTS_SOURCE_SECRET",
        "scope_envs": [
          "dev",
          "staging",
          "prod"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "mayalerts_source_auth"
        ],
        "owner": "observability operator",
        "notes": "Shared secret used by MayAlerts to trust LocalRAG alert events."
      },
      {
        "name": "MAYALERTS_GITLAB_TOKEN",
        "scope_envs": [
          "staging",
          "prod"
        ],
        "kind": "secret",
        "masked": true,
        "protected": true,
        "required_for": [
          "alert_to_gitlab_routing"
        ],
        "owner": "observability operator",
        "notes": "GitLab token with minimal issue create/comment/label permissions for myprojects/localrag."
      }
    ]
  },
  "kiwi": {
    "endpoint": "https://kiwi.it360.ru/json-rpc/",
    "sync_script": "scripts/kiwi_sync_pytest.py",
    "mapping_file": "tests/kiwi_sync_mapping.json",
    "current_mapping_run_id": 113,
    "product": {
      "name": "LocalRAG",
      "classification": "Application",
      "description": "Local-first RAG application with API, UI, Docker Compose runtime, and release quality gates."
    },
    "version": {
      "name": "0.9.0",
      "release": "0.9.0",
      "branch": "dev"
    },
    "build": {
      "name_template": "localrag-0.9.0-${CI_COMMIT_SHORT_SHA}",
      "source_ref": "${CI_COMMIT_SHA}",
      "artifact": "dist/LocalRAG-v0.9.0.zip"
    },
    "baseline_cases": {
      "category": "API",
      "priority": "P1",
      "case_prefix": "TC-LRAG",
      "coverage": [
        "web index smoke",
        "status, health, and meta endpoints",
        "ask validation",
        "history API",
        "role behavior",
        "model manager",
        "language guard"
      ]
    }
  },
  "cloudflare": {
    "zone_placeholder": "localrag.example.com",
    "dns_records": [
      {
        "environment": "dev",
        "type": "CNAME",
        "name": "dev.localrag.example.com",
        "target": "coolify-origin.example.net",
        "proxied": true,
        "ttl": "auto"
      },
      {
        "environment": "staging",
        "type": "CNAME",
        "name": "staging.localrag.example.com",
        "target": "coolify-origin.example.net",
        "proxied": true,
        "ttl": "auto"
      },
      {
        "environment": "prod",
        "type": "CNAME",
        "name": "localrag.example.com",
        "target": "coolify-origin.example.net",
        "proxied": true,
        "ttl": "auto"
      }
    ],
    "tls": {
      "mode": "Full (strict)",
      "minimum_tls_version": "1.2",
      "always_use_https": true,
      "automatic_https_rewrites": true,
      "origin_certificate": "Cloudflare Origin Certificate or public ACME certificate installed at the Coolify reverse proxy",
      "hsts": "enable only after staging and prod hostnames serve HTTPS successfully"
    },
    "security_rules": [
      "Do not cache API responses for /api/*.",
      "Allow Uptime Kuma and MayAlerts synthetic checks to reach /api/health and /api/meta.",
      "Restrict /docs outside dev/staging if FastAPI docs remain enabled."
    ]
  },
  "coolify": {
    "application": {
      "name": "localrag",
      "type": "docker-compose",
      "compose_file": "docker-compose.yml",
      "env_file_template": "deploy/coolify/localrag.env.example",
      "container_port": 7860,
      "healthcheck": "http://localhost:7860/api/health",
      "persistent_volumes": [
        "ollama_data",
        "vectorstore bind mount",
        "hf_cache bind mount"
      ]
    },
    "environment_variables": [
      "SERVICE_NAME",
      "APP_ENV",
      "APP_VERSION",
      "APP_RELEASE",
      "APP_INSTANCE_ID",
      "BUILD_DATE_UTC",
      "SEO_PUBLIC_BASE_URL",
      "SEO_INDEX_APP",
      "LLM_MODEL",
      "OLLAMA_TAG",
      "EMBED_MODEL",
      "HOST_FS_ROOT",
      "HOST_FS_MOUNT",
      "DOCS_PATH",
      "PDF_PATH",
      "HOST_DOCS_PATH",
      "HF_HOME",
      "OLLAMA_BASE_URL",
      "MODEL_NAME",
      "EMBEDDINGS_MODEL_NAME",
      "GRAYLOG_HTTP_INPUT_URL",
      "GRAYLOG_HTTP_INPUT_TOKEN",
      "MAYALERTS_SOURCE_SECRET"
    ],
    "promotion": {
      "dev": "manual Coolify deploy from dev or feature branch",
      "staging": "manual deploy after pytest_ci; run quality_gate_live against LOCALRAG_STAGING_BASE_URL",
      "prod": "manual protected promotion after staging green and tag/package approval"
    }
  },
  "monitoring": {
    "graylog": {
      "input": "HTTP GELF or compatible structured log input",
      "required_base_fields": [
        "service_name",
        "app_env",
        "app_release",
        "app_version",
        "app_instance_id",
        "correlation_id",
        "event_name",
        "event_domain",
        "event_outcome",
        "severity",
        "message",
        "timestamp_utc",
        "host"
      ],
      "event_definitions": [
        "localrag_health_down",
        "localrag_release_drift",
        "localrag_index_build_failed",
        "localrag_indexing_stuck",
        "localrag_ask_error_rate_high",
        "localrag_ollama_unavailable",
        "localrag_default_model_missing",
        "localrag_release_smoke_failed",
        "localrag_observability_contract_violation"
      ],
      "privacy_rule": "Never emit raw questions, answers, source passages, local filesystem paths, cookies, or custom role prompts."
    },
    "uptime_kuma": {
      "checks": [
        {
          "name": "localrag-dev-health",
          "environment": "dev",
          "type": "http",
          "url_template": "${LOCALRAG_DEV_BASE_URL}/api/health",
          "interval_seconds": 60,
          "retries": 3,
          "accepted_status": [
            200
          ]
        },
        {
          "name": "localrag-staging-health",
          "environment": "staging",
          "type": "http-json",
          "url_template": "${LOCALRAG_STAGING_BASE_URL}/api/health",
          "interval_seconds": 60,
          "retries": 3,
          "accepted_status": [
            200
          ],
          "json_expectations": [
            "ok == true",
            "app.app_env == staging"
          ]
        },
        {
          "name": "localrag-staging-meta",
          "environment": "staging",
          "type": "http-json",
          "url_template": "${LOCALRAG_STAGING_BASE_URL}/api/meta",
          "interval_seconds": 300,
          "retries": 2,
          "json_expectations": [
            "name == LocalRAG",
            "default_model == qwen3.5:9b",
            "app_release is set"
          ]
        },
        {
          "name": "localrag-prod-health",
          "environment": "prod",
          "type": "http-json",
          "url_template": "${LOCALRAG_PROD_BASE_URL}/api/health",
          "interval_seconds": 30,
          "retries": 3,
          "accepted_status": [
            200
          ],
          "json_expectations": [
            "ok == true",
            "app.app_env == prod"
          ]
        },
        {
          "name": "localrag-prod-ui",
          "environment": "prod",
          "type": "http",
          "url_template": "${LOCALRAG_PROD_BASE_URL}/",
          "interval_seconds": 60,
          "retries": 3,
          "accepted_status": [
            200
          ],
          "body_expectations": [
            "LocalRAG"
          ]
        }
      ]
    },
    "mayalerts": {
      "source": "localrag-platform-delivery",
      "source_secret_variable": "MAYALERTS_SOURCE_SECRET",
      "alert_fingerprint_template": "service_name|app_env|alert_name|severity|dedupe_resource|app_release_major_minor",
      "gitlab_routing": {
        "project_path": "myprojects/localrag",
        "non_prod_labels": [
          "area::observability",
          "monitoring",
          "source::mayalerts",
          "alert::non-prod",
          "sdlc::triage"
        ],
        "prod_labels": [
          "area::observability",
          "monitoring",
          "source::mayalerts",
          "alert::prod",
          "sdlc::triage"
        ],
        "prod_confidential": true,
        "title_template": "[ALERT][${APP_ENV}][${SEVERITY}][localrag] ${ALERT_SUMMARY}"
      },
      "privacy_check_fields": [
        "raw_question_text_included",
        "raw_answer_text_included",
        "source_passages_included",
        "raw_filesystem_paths_included"
      ]
    }
  },
  "definition_of_done": {
    "ci_cd_baseline_and_secret_map": true,
    "environments_confirmed": [
      "dev",
      "staging",
      "prod"
    ],
    "kiwi_product_version_build_baseline": true,
    "cloudflare_dns_tls_plan": true,
    "coolify_application_env_set": true,
    "monitoring_baseline": [
      "graylog_event_definitions",
      "uptime_kuma_checks",
      "mayalerts_source_secret",
      "alert_to_gitlab_routing"
    ]
  }
}
