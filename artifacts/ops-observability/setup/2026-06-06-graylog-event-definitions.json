{
  "artifact_type": "graylog_event_definition_plan",
  "artifact_version": "1.0",
  "project": "LocalRAG",
  "track": "ops-observability",
  "stage": "setup",
  "gitlab_issue": "#43",
  "date": "2026-06-06",
  "status": "ready-for-import",
  "service_name": "localrag",
  "source_contract": "artifacts/ops-observability/design/2026-06-06-observability-contract-alert-policy.md",
  "graylog_stream": {
    "name": "localrag-application",
    "matching_rule": "service_name:localrag OR _service_name:localrag",
    "retention_note": "Retention is configured outside this repository; alert evidence must remain privacy-safe."
  },
  "notification": {
    "name": "mayalerts-localrag-webhook",
    "type": "http-webhook",
    "url_variable": "MAYALERTS_GRAYLOG_SOURCE_WEBHOOK_URL",
    "secret_header": "X-LocalRAG-Alert-Secret",
    "secret_variable": "MAYALERTS_GRAYLOG_SOURCE_SECRET",
    "payload_contract": {
      "service_name": "localrag",
      "app_env": "${event.fields.app_env}",
      "app_release": "${event.fields.app_release}",
      "app_instance_id": "${event.fields.app_instance_id}",
      "alert_name": "${event_definition.alert_name}",
      "severity": "${event_definition.mayalerts_severity}",
      "dedupe_resource": "${event.fields.dedupe_resource}",
      "correlation_ids": "${event.fields.correlation_id}",
      "alert_value": "${event.fields.alert_value}",
      "alert_threshold": "${event_definition.threshold_summary}",
      "alert_window": "${event_definition.window}"
    }
  },
  "event_definitions": [
    {
      "alert_name": "localrag_service_error_5xx",
      "title": "LocalRAG service 5xx errors",
      "description": "Service emitted repeated 5xx responses for a route.",
      "environments": [
        "staging",
        "prod"
      ],
      "graylog_condition_type": "aggregation",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND event_name:http_request_completed AND event_outcome:failure AND http_status_class:5xx",
      "group_by": [
        "app_env",
        "http_route",
        "app_release"
      ],
      "window": "5m",
      "threshold": {
        "metric": "count",
        "operator": ">=",
        "value": 3
      },
      "mayalerts_severity": {
        "staging": "p2",
        "prod": "p1"
      },
      "dedupe_resource_template": "route:${http_route}",
      "critical_workflows": [
        "ui-open",
        "ask",
        "model-manager",
        "embedding-manager"
      ]
    },
    {
      "alert_name": "localrag_health_down",
      "title": "LocalRAG health endpoint down",
      "description": "Health endpoint failed or returned an unhealthy payload for consecutive checks.",
      "environments": [
        "staging",
        "prod"
      ],
      "graylog_condition_type": "aggregation",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND (event_name:synthetic_check_failed OR (event_name:http_request_completed AND http_route:/api/health AND event_outcome:failure))",
      "group_by": [
        "app_env",
        "app_instance_id",
        "app_release"
      ],
      "window": "3m",
      "threshold": {
        "metric": "count",
        "operator": ">=",
        "value": 3
      },
      "mayalerts_severity": {
        "staging": "p2",
        "prod": "p1"
      },
      "dedupe_resource_template": "app_instance:${app_instance_id}",
      "critical_workflows": [
        "health",
        "index-readiness"
      ]
    },
    {
      "alert_name": "localrag_index_build_failed",
      "title": "LocalRAG index build failed",
      "description": "Index build or reindex job failed.",
      "environments": [
        "dev",
        "staging",
        "prod"
      ],
      "graylog_condition_type": "filter",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND ((event_name:index_build_completed AND event_outcome:failure) OR index_status:build_failed)",
      "group_by": [
        "app_env",
        "docs_path_hash",
        "embedding_model"
      ],
      "window": "10m",
      "threshold": {
        "metric": "count",
        "operator": ">=",
        "value": 1
      },
      "mayalerts_severity": {
        "dev": "p3",
        "staging": "p2",
        "prod": "p2"
      },
      "dedupe_resource_template": "docs_path:${docs_path_hash}|embedding:${embedding_model}",
      "critical_workflows": [
        "reindex",
        "ask"
      ]
    },
    {
      "alert_name": "localrag_indexing_stuck",
      "title": "LocalRAG indexing stuck",
      "description": "Indexing has stayed active beyond the environment threshold.",
      "environments": [
        "dev",
        "staging",
        "prod"
      ],
      "graylog_condition_type": "aggregation",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND index_status:indexing",
      "group_by": [
        "app_env",
        "app_instance_id",
        "docs_path_hash"
      ],
      "window": "30m",
      "threshold": {
        "metric": "max(duration_ms)",
        "operator": ">",
        "value": 900000
      },
      "mayalerts_severity": {
        "dev": "p3",
        "staging": "p2",
        "prod": "p2"
      },
      "dedupe_resource_template": "app_instance:${app_instance_id}|docs_path:${docs_path_hash}",
      "critical_workflows": [
        "reindex",
        "index-readiness"
      ]
    },
    {
      "alert_name": "localrag_ask_error_rate_high",
      "title": "LocalRAG ask workflow error rate high",
      "description": "Ask workflow failures crossed the configured error-rate threshold.",
      "environments": [
        "staging",
        "prod"
      ],
      "graylog_condition_type": "aggregation",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND http_route:/api/ask",
      "group_by": [
        "app_env",
        "model_name",
        "answer_language",
        "app_release"
      ],
      "window": "10m",
      "threshold": {
        "metric": "failure_count / total_count",
        "operator": ">",
        "value": 0.05,
        "minimum_failure_count": 3
      },
      "mayalerts_severity": {
        "staging": "p2",
        "prod": "p1"
      },
      "dedupe_resource_template": "route:/api/ask|model:${model_name}",
      "critical_workflows": [
        "ask",
        "source-inspection"
      ]
    },
    {
      "alert_name": "localrag_ollama_unavailable",
      "title": "Ollama unavailable to LocalRAG",
      "description": "Ollama tags or generation calls failed for the configured window.",
      "environments": [
        "dev",
        "staging",
        "prod"
      ],
      "graylog_condition_type": "aggregation",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND event_domain:ollama AND event_outcome:failure",
      "group_by": [
        "app_env",
        "model_name",
        "app_release"
      ],
      "window": "2m",
      "threshold": {
        "metric": "count",
        "operator": ">=",
        "value": 2
      },
      "mayalerts_severity": {
        "dev": "p3",
        "staging": "p2",
        "prod": "p1"
      },
      "dedupe_resource_template": "ollama:${model_name}",
      "critical_workflows": [
        "ask",
        "model-manager"
      ]
    },
    {
      "alert_name": "localrag_default_model_missing",
      "title": "LocalRAG default model missing",
      "description": "Default model from /api/meta is absent from the installed Ollama model list.",
      "environments": [
        "staging",
        "prod"
      ],
      "graylog_condition_type": "filter",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND event_name:default_model_missing",
      "group_by": [
        "app_env",
        "model_name",
        "app_release"
      ],
      "window": "5m",
      "threshold": {
        "metric": "count",
        "operator": ">=",
        "value": 1
      },
      "mayalerts_severity": {
        "staging": "p2",
        "prod": "p2"
      },
      "dedupe_resource_template": "model:${model_name}",
      "critical_workflows": [
        "ask",
        "model-manager",
        "release-validation"
      ]
    },
    {
      "alert_name": "localrag_release_smoke_failed",
      "title": "LocalRAG release smoke failed",
      "description": "Release smoke check failed any configured health, meta, or ask check.",
      "environments": [
        "staging",
        "prod"
      ],
      "graylog_condition_type": "filter",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND event_name:release_smoke_check_completed AND event_outcome:failure",
      "group_by": [
        "app_env",
        "base_url_hash",
        "app_release"
      ],
      "window": "30m",
      "threshold": {
        "metric": "count",
        "operator": ">=",
        "value": 1
      },
      "mayalerts_severity": {
        "staging": "p2",
        "prod": "p2"
      },
      "dedupe_resource_template": "release:${app_release}|check:release-smoke",
      "critical_workflows": [
        "health",
        "release-metadata",
        "ask",
        "release-validation"
      ]
    },
    {
      "alert_name": "localrag_observability_contract_violation",
      "title": "LocalRAG observability contract violation",
      "description": "Required field is missing or unsafe private content was detected in telemetry.",
      "environments": [
        "dev",
        "staging",
        "prod"
      ],
      "graylog_condition_type": "filter",
      "search_query": "(service_name:localrag OR _service_name:localrag) AND event_name:observability_contract_violation",
      "group_by": [
        "app_env",
        "field",
        "event_domain"
      ],
      "window": "5m",
      "threshold": {
        "metric": "count",
        "operator": ">=",
        "value": 1
      },
      "mayalerts_severity": {
        "dev": "p3",
        "staging": "p2",
        "prod": "p2"
      },
      "dedupe_resource_template": "field:${field}|domain:${event_domain}",
      "critical_workflows": [
        "observability",
        "privacy"
      ],
      "noise_control": "Never suppress violations that include unsafe private content leakage."
    }
  ],
  "post_import_checks": [
    "Each event definition is attached to the localrag-application stream.",
    "Each event definition uses the mayalerts-localrag-webhook notification.",
    "Every alert payload includes service_name, app_env, app_release, alert_name, severity, dedupe_resource, and correlation_ids when available.",
    "Graylog evidence excludes raw questions, answers, source passages, raw filesystem paths, cookies, and secrets."
  ]
}
