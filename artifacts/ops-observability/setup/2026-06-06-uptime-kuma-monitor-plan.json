{
  "artifact_type": "uptime_kuma_monitor_plan",
  "artifact_version": "1.0",
  "project": "LocalRAG",
  "track": "ops-observability",
  "stage": "setup",
  "gitlab_issue": "#43",
  "date": "2026-06-06",
  "status": "ready-for-import",
  "service_name": "localrag",
  "primary_gitlab_project": "https://lab.it360.ru/myprojects/localrag",
  "environment_aliases": {
    "test": {
      "canonical_app_env": "staging",
      "reason": "The issue asks for test endpoints; the design contract routes non-prod synthetic alerts through APP_ENV=staging."
    },
    "prod": {
      "canonical_app_env": "prod",
      "reason": "Production alerts use confidential GitLab issue routing by default."
    }
  },
  "operator_variables": {
    "UPTIME_KUMA_BASE_URL": "https://uptime-kuma.example.local",
    "LOCALRAG_TEST_BASE_URL": "https://localrag-test.example.local",
    "LOCALRAG_PROD_BASE_URL": "https://localrag.example.local",
    "LOCALRAG_EXPECTED_MODEL": "qwen3.5:9b",
    "LOCALRAG_TEST_EXPECTED_DOCS_PATH": "C:/Temp/PDF",
    "LOCALRAG_PROD_EXPECTED_DOCS_PATH": "C:/Sergey/Lab360/localrag/files",
    "LOCALRAG_TEST_RELEASE_SMOKE_PUSH_KEY": "<create-in-uptime-kuma>",
    "LOCALRAG_PROD_RELEASE_SMOKE_PUSH_KEY": "<create-in-uptime-kuma>"
  },
  "notification_routes": {
    "non_prod": "mayalerts-localrag-non-prod",
    "prod": "mayalerts-localrag-prod"
  },
  "defaults": {
    "http_method": "GET",
    "timeout_seconds": 20,
    "retry_interval_seconds": 30,
    "accepted_status_codes": [
      "200"
    ],
    "headers": {
      "X-Request-ID": "uptime-kuma:${monitor_name}:${timestamp}"
    },
    "privacy_rule": "Monitor names, URLs, and messages must not include raw local filesystem paths, source excerpts, user questions, answers, cookies, or secrets."
  },
  "monitors": [
    {
      "name": "localrag-test-health",
      "monitor_kind": "http",
      "target_environment": "test",
      "mayalerts_app_env": "staging",
      "url_template": "${LOCALRAG_TEST_BASE_URL}/api/health",
      "interval_seconds": 60,
      "timeout_seconds": 20,
      "retries": 3,
      "retry_interval_seconds": 30,
      "accepted_status_codes": [
        "200"
      ],
      "expected_json": {
        "ok": true,
        "app.name": "LocalRAG",
        "index.status": "loading|ready_loaded|indexing|build_failed|ready_ask|no_documents|saved_failed|changes_detected"
      },
      "critical_workflows": [
        "health",
        "index-readiness"
      ],
      "mayalerts_alert_name": "localrag_health_down",
      "mayalerts_severity": "p2",
      "dedupe_resource": "route:/api/health",
      "notification_route": "mayalerts-localrag-non-prod",
      "notes": "Create as a standard HTTP monitor. If Uptime Kuma cannot assert JSON fields directly, route the HTTP status to MayAlerts and leave JSON validation to release smoke."
    },
    {
      "name": "localrag-test-meta",
      "monitor_kind": "http",
      "target_environment": "test",
      "mayalerts_app_env": "staging",
      "url_template": "${LOCALRAG_TEST_BASE_URL}/api/meta",
      "interval_seconds": 300,
      "timeout_seconds": 20,
      "retries": 2,
      "retry_interval_seconds": 60,
      "accepted_status_codes": [
        "200"
      ],
      "keyword": "LocalRAG",
      "critical_workflows": [
        "release-metadata"
      ],
      "mayalerts_alert_name": "localrag_release_drift",
      "mayalerts_severity": "p2",
      "dedupe_resource": "route:/api/meta",
      "notification_route": "mayalerts-localrag-non-prod",
      "notes": "Pair with expected release validation in scripts/release_check.py because Uptime Kuma keyword checks are intentionally coarse."
    },
    {
      "name": "localrag-test-ui",
      "monitor_kind": "http",
      "target_environment": "test",
      "mayalerts_app_env": "staging",
      "url_template": "${LOCALRAG_TEST_BASE_URL}/",
      "interval_seconds": 300,
      "timeout_seconds": 20,
      "retries": 2,
      "retry_interval_seconds": 60,
      "accepted_status_codes": [
        "200"
      ],
      "keyword": "LocalRAG",
      "critical_workflows": [
        "ui-open"
      ],
      "mayalerts_alert_name": "localrag_ui_unavailable",
      "mayalerts_severity": "p3",
      "dedupe_resource": "route:/",
      "notification_route": "mayalerts-localrag-non-prod",
      "notes": "This is a reachability check only; browser layout verification remains a separate QA gate."
    },
    {
      "name": "localrag-test-release-smoke",
      "monitor_kind": "push",
      "target_environment": "test",
      "mayalerts_app_env": "staging",
      "push_url_template": "${UPTIME_KUMA_BASE_URL}/api/push/${LOCALRAG_TEST_RELEASE_SMOKE_PUSH_KEY}?status=${status}&msg=${message}&ping=${duration_ms}",
      "heartbeat_interval_seconds": 900,
      "grace_seconds": 180,
      "job_command_template": "python3 scripts/release_check.py --base-url ${LOCALRAG_TEST_BASE_URL} --expected-model ${LOCALRAG_EXPECTED_MODEL} --expected-docs-path ${LOCALRAG_TEST_EXPECTED_DOCS_PATH}",
      "success_push_message": "release-smoke-ok",
      "failure_push_message": "release-smoke-failed",
      "critical_workflows": [
        "health",
        "release-metadata",
        "ask"
      ],
      "mayalerts_alert_name": "localrag_release_smoke_failed",
      "mayalerts_severity": "p2",
      "dedupe_resource": "check:release-smoke",
      "notification_route": "mayalerts-localrag-non-prod",
      "notes": "Run from the NAS worker or release runner. The push body must include only check names, result, duration, release, and correlation IDs."
    },
    {
      "name": "localrag-prod-health",
      "monitor_kind": "http",
      "target_environment": "prod",
      "mayalerts_app_env": "prod",
      "url_template": "${LOCALRAG_PROD_BASE_URL}/api/health",
      "interval_seconds": 30,
      "timeout_seconds": 15,
      "retries": 3,
      "retry_interval_seconds": 20,
      "accepted_status_codes": [
        "200"
      ],
      "expected_json": {
        "ok": true,
        "app.name": "LocalRAG",
        "index.ready": true
      },
      "critical_workflows": [
        "health",
        "index-readiness"
      ],
      "mayalerts_alert_name": "localrag_health_down",
      "mayalerts_severity": "p1",
      "dedupe_resource": "route:/api/health",
      "notification_route": "mayalerts-localrag-prod",
      "notes": "Production readiness requires ok=true and index.ready=true before traffic is considered healthy."
    },
    {
      "name": "localrag-prod-meta",
      "monitor_kind": "http",
      "target_environment": "prod",
      "mayalerts_app_env": "prod",
      "url_template": "${LOCALRAG_PROD_BASE_URL}/api/meta",
      "interval_seconds": 300,
      "timeout_seconds": 15,
      "retries": 2,
      "retry_interval_seconds": 60,
      "accepted_status_codes": [
        "200"
      ],
      "keyword": "LocalRAG",
      "critical_workflows": [
        "release-metadata"
      ],
      "mayalerts_alert_name": "localrag_release_drift",
      "mayalerts_severity": "p2",
      "dedupe_resource": "route:/api/meta",
      "notification_route": "mayalerts-localrag-prod",
      "notes": "Compare the response with the deployment manifest through the release smoke push job."
    },
    {
      "name": "localrag-prod-ui",
      "monitor_kind": "http",
      "target_environment": "prod",
      "mayalerts_app_env": "prod",
      "url_template": "${LOCALRAG_PROD_BASE_URL}/",
      "interval_seconds": 300,
      "timeout_seconds": 15,
      "retries": 2,
      "retry_interval_seconds": 60,
      "accepted_status_codes": [
        "200"
      ],
      "keyword": "LocalRAG",
      "critical_workflows": [
        "ui-open"
      ],
      "mayalerts_alert_name": "localrag_ui_unavailable",
      "mayalerts_severity": "p2",
      "dedupe_resource": "route:/",
      "notification_route": "mayalerts-localrag-prod",
      "notes": "Do not use this as the sole prod health signal; /api/health remains primary."
    },
    {
      "name": "localrag-prod-release-smoke",
      "monitor_kind": "push",
      "target_environment": "prod",
      "mayalerts_app_env": "prod",
      "push_url_template": "${UPTIME_KUMA_BASE_URL}/api/push/${LOCALRAG_PROD_RELEASE_SMOKE_PUSH_KEY}?status=${status}&msg=${message}&ping=${duration_ms}",
      "heartbeat_interval_seconds": 1800,
      "grace_seconds": 300,
      "job_command_template": "python3 scripts/release_check.py --base-url ${LOCALRAG_PROD_BASE_URL} --expected-model ${LOCALRAG_EXPECTED_MODEL} --expected-docs-path ${LOCALRAG_PROD_EXPECTED_DOCS_PATH}",
      "success_push_message": "release-smoke-ok",
      "failure_push_message": "release-smoke-failed",
      "critical_workflows": [
        "health",
        "release-metadata",
        "ask"
      ],
      "mayalerts_alert_name": "localrag_release_smoke_failed",
      "mayalerts_severity": "p2",
      "dedupe_resource": "check:release-smoke",
      "notification_route": "mayalerts-localrag-prod",
      "notes": "Use only an approved non-private corpus and safe question for the ask check."
    }
  ],
  "post_import_checks": [
    "Every monitor has tags: service:localrag, project:myprojects/localrag, track:ops-observability, env:<test|prod>.",
    "HTTP monitors send failures to the matching MayAlerts route.",
    "Push monitors are backed by scheduled release_check.py jobs on the NAS or release runner.",
    "Uptime Kuma alert text excludes raw documents, questions, answers, paths, cookies, and secrets."
  ]
}
